# SAEC-O&G - Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual Environments
.venv/
venv/
ENV/

# Environment Variables (CRITICAL - API keys)
.env
.env.local
.env.*.local

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Local assistant settings
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db
Desktop.ini
nul

# Outputs (regenerable)
Extraction/outputs/work/
Extraction/outputs/consolidated/*.xlsx

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
