# ===========================================
# SAEC-O&G - Configuração de APIs
# ===========================================
# Copie este arquivo para .env e preencha suas chaves
# cp .env.template .env

# Anthropic (Claude) - opcional (fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (GPT) - opcional (fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Registro dinâmico de provedores (YAML) - opcional, recomendado
# Exemplo: config/providers.yaml
LLM_PROVIDERS_FILE=config/providers.yaml

# ===========================================
# Modelos
# ===========================================
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPENAI_MODEL=gpt-5.2-2025-12-11

# ===========================================
# Estratégia de Extração
# ===========================================
# true = ativa fluxo de extração + repair com fallback
# false = usa apenas PRIMARY_PROVIDER (sem segunda passada)
USE_TWO_PASS=true
PRIMARY_PROVIDER=ollama

# ===========================================
# Limites
# ===========================================
MAX_REPAIR_ATTEMPTS=3
IMAGE_DPI=150
RAG_ENABLED=true
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=3
RAG_MIN_CONTEXT_CHARS=1200
RAG_MIN_CONTEXT_RATIO=0.15
STRIP_REPEATED_LINES=true
REPEAT_LINE_MIN_FRACTION=0.5
REPEAT_LINE_MAX_LEN=80

# ===========================================
# Caminhos (opcionais)
# ===========================================
# Nome da pasta de artigos (relativo à raiz do projeto)
ARTICLES_DIR=02 T2

# Overrides absolutos (usados pela GUI com projetos dedicados)
# SAEC_ARTICLES_PATH=C:\\data\\saec\\projects\\alpha\\inputs\\articles
# SAEC_EXTRACTION_PATH=C:\\data\\saec\\projects\\alpha

# ===========================================
# Configurações de PDF (opcionais)
# ===========================================
# Região de header a ignorar (% da altura da página)
PDF_HEADER_REGION=0.12

# Região de footer a ignorar (% da altura da página)
PDF_FOOTER_REGION=0.12

# Área mínima de imagem para considerar relevante (% da área da página)
PDF_MIN_IMAGE_AREA_RATIO=0.03

# ===========================================
# Ollama (local + cloud via proxy)
# ===========================================
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelos cloud (rodam nos servidores, sem usar VRAM local)
OLLAMA_MODEL_CLOUD=glm-4.7:cloud
OLLAMA_MODEL_CLOUD_FALLBACK=kimi-k2.5:cloud

# Modelos locais (devem caber na GPU - max ~8GB para 10GB VRAM)
OLLAMA_MODEL_CODER=qwen3-vl:8b
OLLAMA_MODEL_VISION=qwen3-vl:8b

# Modelos por tarefa no pipeline cascade
OLLAMA_EXTRACTION_MODEL=glm-4.7:cloud
OLLAMA_REPAIR_MODEL=glm-4.7:cloud
OLLAMA_OCR_MODEL=glm-ocr:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest

# Estratégia de cascata (cloud-first com fallback para API)
EXTRACTION_STRATEGY=local_first
LOCAL_CONFIDENCE_THRESHOLD=0.7
USE_CASCADE=true

# Prompt caching
PROMPT_CACHE_ENABLED=true
PROMPT_CACHE_KEY=saec_guia_v3_3
PROMPT_CACHE_RETENTION=in_memory
ANTHROPIC_CACHE_TTL=5m
PROMPT_MIN_TEXT_CHARS=0
